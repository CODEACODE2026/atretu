# App
NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=http://localhost:3333

# API
API_PORT=3333
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-local-env

# Database
DATABASE_URL=postgresql://atretu:atretu@localhost:5432/atretu_dev?schema=public

# Redis / Jobs
REDIS_URL=redis://localhost:6379

# Private files
PRIVATE_STORAGE_PATH=./storage/private
MAX_UPLOAD_MB=10

# Sicredi - do not fill real credentials in this file
SICREDI_ENV=homologation
SICREDI_CLIENT_ID=
SICREDI_CLIENT_SECRET=

