# App
NODE_ENV=development

# Web
NEXT_PUBLIC_API_URL=http://localhost:3333

# API
API_PORT=3333
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-local-env
JWT_EXPIRES_IN=2h
ADMIN_SETUP_TOKEN=change-me-in-local-env
PASSWORD_HASH_ROUNDS=12
AUTH_RATE_LIMIT_TTL_MS=60000
AUTH_RATE_LIMIT_MAX=5
RATE_LIMIT_MAX_BUCKETS=10000
TRUSTED_PROXY_HOPS=0

# Database
DATABASE_URL=postgresql://atretu:atretu@localhost:5432/atretu_dev?schema=public

# Redis / Jobs
REDIS_URL=redis://localhost:6379

# Private files
DOCUMENT_STORAGE_DIR=/opt/codeacode/storage/atretu/private-documents
DOCUMENT_MAX_SIZE_BYTES=8388608

# Sicredi - do not fill real credentials in this file
SICREDI_ENV=sandbox
SICREDI_AUTH_URL=https://api-parceiro.sicredi.com.br/sb/auth/openapi/token
SICREDI_BASE_URL=https://api-parceiro.sicredi.com.br/sb
SICREDI_API_KEY=
SICREDI_USERNAME=
SICREDI_PASSWORD=
SICREDI_COOPERATIVA=
SICREDI_POSTO=
SICREDI_CODIGO_BENEFICIARIO=<codigo real fornecido pelo Sicredi>
SICREDI_HTTP_TIMEOUT_MS=10000
SICREDI_REQUIRE_PAYER_ADDRESS=false
