{
  "name": "@atretu/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "tsx src/auth/auth.service.spec.ts && tsx src/base-records/base-records.service.spec.ts && tsx src/students/cpf.spec.ts && tsx src/bus-assignments/capacity.spec.ts && tsx src/documents/document-file.spec.ts && tsx src/pre-registrations/pre-registration-public.dto.spec.ts && tsx src/config/env.spec.ts",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "smoke:base-records": "node scripts/smoke-base-records.mjs",
    "smoke:students": "node scripts/smoke-students.mjs",
    "smoke:bus-assignments": "node scripts/smoke-bus-assignments.mjs",
    "smoke:documents": "node scripts/smoke-documents.mjs",
    "smoke:pre-registrations": "node scripts/smoke-pre-registrations.mjs",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@atretu/shared": "0.0.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/multer": "^2.2.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2"
  }
}
