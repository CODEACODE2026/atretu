  phone                  String?                   @db.VarChar(30)
  email                  String?                   @db.VarChar(180)
  addressStreet          String                    @map("address_street") @db.VarChar(180)
  addressNumber          String                    @map("address_number") @db.VarChar(30)
  addressNeighborhood    String                    @map("address_neighborhood") @db.VarChar(120)
  addressCity            String                    @map("address_city") @db.VarChar(120)
  guardianFullName       String?                   @map("guardian_full_name") @db.VarChar(160)
  guardianCpf            String?                   @map("guardian_cpf") @db.VarChar(11)
  guardianRg             String?                   @map("guardian_rg") @db.VarChar(30)
  academicYearId         String                    @map("academic_year_id") @db.Uuid
  institutionId          String                    @map("institution_id") @db.Uuid
  shiftId                String                    @map("shift_id") @db.Uuid
  course                 String                    @db.VarChar(140)
  grade                  String                    @db.VarChar(40)
  requestFingerprintHash String?                   @map("request_fingerprint_hash") @db.VarChar(64)
  reviewedByUserId       String?                   @map("reviewed_by_user_id") @db.Uuid
  reviewedAt             DateTime?                 @map("reviewed_at") @db.Timestamptz(6)
  rejectionReason        String?                   @map("rejection_reason") @db.VarChar(500)
  approvedStudentId      String?                   @unique @map("approved_student_id") @db.Uuid
  createdAt              DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
