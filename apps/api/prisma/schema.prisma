model BankSlipIssueBatchItem {
  id               String                       @id @default(uuid()) @db.Uuid
  batchId          String                       @map("batch_id") @db.Uuid
  invoiceId        String                       @map("invoice_id") @db.Uuid
  bankSlipId       String?                      @map("bank_slip_id") @db.Uuid
  status           BankSlipIssueBatchItemStatus @default(QUEUED)
  attempts         Int                          @default(0)
  nextAttemptAt    DateTime?                    @map("next_attempt_at") @db.Timestamptz(6)
  lockedAt         DateTime?                    @map("locked_at") @db.Timestamptz(6)
  startedAt        DateTime?                    @map("started_at") @db.Timestamptz(6)
  finishedAt       DateTime?                    @map("finished_at") @db.Timestamptz(6)
  lastErrorCode    String?                      @map("last_error_code") @db.VarChar(80)
  lastErrorMessage String?                      @map("last_error_message") @db.VarChar(500)
  skipReason       String?                      @map("skip_reason") @db.VarChar(500)
  createdAt        DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                     @updatedAt @map("updated_at") @db.Timestamptz(6)
  batch            BankSlipIssueBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
