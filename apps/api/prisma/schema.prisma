  institution            Institution               @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  shift                  Shift                     @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  reviewedBy             User?                     @relation("PreRegistrationReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  approvedStudent        Student?                  @relation(fields: [approvedStudentId], references: [id], onDelete: SetNull)
  documents              PreRegistrationDocument[]

