generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleCode {
  SUPER_ADMIN
  SECRETARIA
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AuditEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  ACCESS_DENIED
  ADMIN_BOOTSTRAP
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum AdministrativeAuditEventType {
  BASE_RECORD_CREATED
  BASE_RECORD_UPDATED
  BASE_RECORD_INACTIVATED
  BASE_RECORD_REACTIVATED
  STUDENT_CREATED
  PERSON_UPDATED
  GUARDIAN_UPDATED
  ENROLLMENT_CREATED
  ENROLLMENT_UPDATED
  ACADEMIC_YEAR_CREATED
  ACADEMIC_YEAR_UPDATED
  ACADEMIC_YEAR_CURRENT_CHANGED
  BUS_ASSIGNMENT_LINKED
  BUS_ASSIGNMENT_RELEASED
  BUS_ASSIGNMENT_SWITCHED
  BUS_CAPACITY_UPDATED
  STUDENT_DOCUMENT_UPLOADED
  STUDENT_DOCUMENT_REPLACED
  STUDENT_DOCUMENT_DOWNLOADED
  STUDENT_DOCUMENT_VIEWED
  STUDENT_DOCUMENT_REMOVED
}

enum StudentStatus {
  ACTIVE
}

enum EnrollmentStatus {
  ACTIVE
}

enum BusAssignmentStatus {
  ACTIVE
  ENDED
}

enum BusAssignmentEndReason {
  RELEASED
  SWITCHED
}

enum BusAssignmentEventType {
  LINKED
  RELEASED
  SWITCHED
}

enum StudentDocumentType {
  CPF
  RG
  PROOF_OF_ADDRESS
  PROOF_OF_ENROLLMENT
}

enum StudentDocumentStatus {
  ACTIVE
  REPLACED
  REMOVED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  name         String     @db.VarChar(120)
  email        String     @unique @db.VarChar(180)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  roles        UserRole[]
  auditLogs    SecurityAuditLog[]
  administrativeAuditLogs AdministrativeAuditLog[]
  uploadedStudentDocuments StudentDocument[] @relation("StudentDocumentUploadedBy")
  removedStudentDocuments  StudentDocument[] @relation("StudentDocumentRemovedBy")

  @@map("users")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  code        RoleCode   @unique
  description String     @db.VarChar(180)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@map("user_roles")
}

model SecurityAuditLog {
  id        String         @id @default(uuid()) @db.Uuid
  eventType AuditEventType @map("event_type")
  userId    String?        @map("user_id") @db.Uuid
  email     String?        @db.VarChar(180)
  ip        String?        @db.VarChar(80)
  userAgent String?        @map("user_agent") @db.VarChar(255)
  metadata  Json?
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@map("security_audit_logs")
}

model Institution {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(140)
  normalizedName String       @unique @map("normalized_name") @db.VarChar(140)
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  enrollments    Enrollment[]

  @@index([status, name])
  @@index([createdAt])
  @@map("institutions")
}

model Shift {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(80)
  normalizedName String       @unique @map("normalized_name") @db.VarChar(80)
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  enrollments    Enrollment[]

  @@index([status, name])
  @@index([createdAt])
  @@map("shifts")
}

model Bus {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(100)
  normalizedName String       @unique @map("normalized_name") @db.VarChar(100)
  capacity       Int
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignments    BusAssignment[]
  eventsFrom     BusAssignmentEvent[] @relation("BusAssignmentEventFromBus")
  eventsTo       BusAssignmentEvent[] @relation("BusAssignmentEventToBus")

  @@index([status, name])
  @@index([createdAt])
  @@map("buses")
}

model AdministrativeAuditLog {
  id        String                       @id @default(uuid()) @db.Uuid
  eventType AdministrativeAuditEventType @map("event_type")
  userId    String?                      @map("user_id") @db.Uuid
  domain    String                       @db.VarChar(40)
  recordId  String                       @map("record_id") @db.Uuid
  metadata  Json?
  createdAt DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([domain, recordId, createdAt])
  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@map("administrative_audit_logs")
}

model Person {
  id                  String    @id @default(uuid()) @db.Uuid
  fullName            String    @map("full_name") @db.VarChar(160)
  normalizedName      String    @map("normalized_name") @db.VarChar(160)
  cpf                 String    @db.VarChar(11)
  rg                  String?   @db.VarChar(30)
  birthDate           DateTime  @map("birth_date") @db.Date
  phone               String?   @db.VarChar(30)
  email               String?   @db.VarChar(180)
  addressStreet       String    @map("address_street") @db.VarChar(180)
  addressNumber       String    @map("address_number") @db.VarChar(30)
  addressNeighborhood String    @map("address_neighborhood") @db.VarChar(120)
  addressCity         String    @map("address_city") @db.VarChar(120)
  addressZipCode      String?   @map("address_zip_code") @db.VarChar(20)
  addressState        String?   @map("address_state") @db.VarChar(2)
  addressComplement   String?   @map("address_complement") @db.VarChar(120)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  student             Student?

  @@unique([cpf])
  @@index([normalizedName])
  @@index([createdAt])
  @@map("people")
}

model Student {
  id          String           @id @default(uuid()) @db.Uuid
  personId    String           @unique @map("person_id") @db.Uuid
  status      StudentStatus    @default(ACTIVE)
  joinedAt    DateTime         @default(now()) @map("joined_at") @db.Date
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  person      Person           @relation(fields: [personId], references: [id], onDelete: Restrict)
  guardian    StudentGuardian?
  enrollments Enrollment[]
  documents   StudentDocument[]

  @@index([status, createdAt])
  @@index([joinedAt])
  @@map("students")
}

model StudentGuardian {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @unique @map("student_id") @db.Uuid
  fullName  String   @map("full_name") @db.VarChar(160)
  cpf       String?  @db.VarChar(11)
  rg        String?  @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([cpf])
  @@map("student_guardians")
}

model AcademicYear {
  id          String       @id @default(uuid()) @db.Uuid
  year        Int          @unique
  isCurrent   Boolean      @default(false) @map("is_current")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  enrollments Enrollment[]

  @@index([isCurrent])
  @@index([createdAt])
  @@map("academic_years")
}

model Enrollment {
  id             String           @id @default(uuid()) @db.Uuid
  studentId      String           @map("student_id") @db.Uuid
  academicYearId String           @map("academic_year_id") @db.Uuid
  institutionId  String           @map("institution_id") @db.Uuid
  shiftId        String           @map("shift_id") @db.Uuid
  course         String           @db.VarChar(140)
  grade          String           @db.VarChar(40)
  status         EnrollmentStatus @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Restrict)
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  institution    Institution      @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  shift          Shift            @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  busAssignments BusAssignment[]
  busAssignmentEvents BusAssignmentEvent[]

  @@unique([studentId, academicYearId])
  @@index([academicYearId, status])
  @@index([institutionId])
  @@index([shiftId])
  @@index([createdAt])
  @@map("enrollments")
}

model BusAssignment {
  id           String                  @id @default(uuid()) @db.Uuid
  enrollmentId String                  @map("enrollment_id") @db.Uuid
  busId        String                  @map("bus_id") @db.Uuid
  status       BusAssignmentStatus     @default(ACTIVE)
  startedAt    DateTime                @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt      DateTime?               @map("ended_at") @db.Timestamptz(6)
  endReason    BusAssignmentEndReason? @map("end_reason")
  note         String?                 @db.VarChar(240)
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  enrollment   Enrollment              @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  bus          Bus                     @relation(fields: [busId], references: [id], onDelete: Restrict)
  events       BusAssignmentEvent[]

  @@index([busId, status])
  @@index([enrollmentId, status])
  @@index([startedAt])
  @@map("bus_assignments")
}

model BusAssignmentEvent {
  id              String                 @id @default(uuid()) @db.Uuid
  enrollmentId    String                 @map("enrollment_id") @db.Uuid
  busAssignmentId String?                @map("bus_assignment_id") @db.Uuid
  fromBusId       String?                @map("from_bus_id") @db.Uuid
  toBusId         String?                @map("to_bus_id") @db.Uuid
  eventType       BusAssignmentEventType @map("event_type")
  note            String?                @db.VarChar(240)
  occurredAt      DateTime               @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  enrollment      Enrollment             @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  busAssignment   BusAssignment?         @relation(fields: [busAssignmentId], references: [id], onDelete: SetNull)
  fromBus         Bus?                   @relation("BusAssignmentEventFromBus", fields: [fromBusId], references: [id], onDelete: SetNull)
  toBus           Bus?                   @relation("BusAssignmentEventToBus", fields: [toBusId], references: [id], onDelete: SetNull)

  @@index([enrollmentId, occurredAt])
  @@index([busAssignmentId, occurredAt])
  @@index([fromBusId, occurredAt])
  @@index([toBusId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("bus_assignment_events")
}

model StudentDocument {
  id               String                @id @default(uuid()) @db.Uuid
  studentId        String                @map("student_id") @db.Uuid
  documentType     StudentDocumentType   @map("document_type")
  storageKey       String                @unique @map("storage_key") @db.VarChar(500)
  originalFileName String                @map("original_file_name") @db.VarChar(255)
  storedFileName   String                @map("stored_file_name") @db.VarChar(120)
  mimeType         String                @map("mime_type") @db.VarChar(80)
  extension        String                @db.VarChar(10)
  sizeBytes        Int                   @map("size_bytes")
  checksumSha256   String                @map("checksum_sha256") @db.VarChar(64)
  status           StudentDocumentStatus @default(ACTIVE)
  uploadedByUserId String?               @map("uploaded_by_user_id") @db.Uuid
  removedByUserId  String?               @map("removed_by_user_id") @db.Uuid
  replacedById     String?               @map("replaced_by_id") @db.Uuid
  replacedAt       DateTime?             @map("replaced_at") @db.Timestamptz(6)
  removedAt        DateTime?             @map("removed_at") @db.Timestamptz(6)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  student          Student               @relation(fields: [studentId], references: [id], onDelete: Restrict)
  uploadedBy       User?                 @relation("StudentDocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  removedBy        User?                 @relation("StudentDocumentRemovedBy", fields: [removedByUserId], references: [id], onDelete: SetNull)
  replacedBy       StudentDocument?      @relation("StudentDocumentReplacement", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces         StudentDocument[]     @relation("StudentDocumentReplacement")

  @@index([studentId, status, documentType])
  @@index([checksumSha256])
  @@index([uploadedByUserId, createdAt])
  @@map("student_documents")
}
