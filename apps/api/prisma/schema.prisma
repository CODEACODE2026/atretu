generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleCode {
  SUPER_ADMIN
  SECRETARIA
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AuditEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  ACCESS_DENIED
  ADMIN_BOOTSTRAP
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum AcademicYearStatus {
  ACTIVE
  ARCHIVED
}

enum AdministrativeAuditEventType {
  BASE_RECORD_CREATED
  BASE_RECORD_UPDATED
  BASE_RECORD_INACTIVATED
  BASE_RECORD_REACTIVATED
  STUDENT_CREATED
  PERSON_UPDATED
  GUARDIAN_UPDATED
  ENROLLMENT_CREATED
  ENROLLMENT_UPDATED
  ACADEMIC_YEAR_CREATED
  ACADEMIC_YEAR_UPDATED
  ACADEMIC_YEAR_CURRENT_CHANGED
  BUS_ASSIGNMENT_LINKED
  BUS_ASSIGNMENT_RELEASED
  BUS_ASSIGNMENT_SWITCHED
  BUS_CAPACITY_UPDATED
  STUDENT_DOCUMENT_UPLOADED
  STUDENT_DOCUMENT_REPLACED
  STUDENT_DOCUMENT_DOWNLOADED
  STUDENT_DOCUMENT_VIEWED
  STUDENT_DOCUMENT_REMOVED
  PRE_REGISTRATION_RECEIVED
  PRE_REGISTRATION_DOCUMENT_UPLOADED
  PRE_REGISTRATION_DOCUMENT_VIEWED
  PRE_REGISTRATION_APPROVED
  PRE_REGISTRATION_REJECTED
  PRE_REGISTRATION_DOCUMENT_PROMOTED
  STUDENT_SUSPENDED
  STUDENT_REACTIVATED
  STUDENT_TERMINATED
  STUDENT_REINSTATED
  STUDENT_REENROLLED
  STUDENT_CARD_ISSUED
  STUDENT_CARD_INVALIDATED
  INVOICE_CREATED
  INVOICE_CANCELLED
  BANK_SLIP_ISSUE_REQUESTED
  BANK_SLIP_ISSUED
  BANK_SLIP_ISSUE_FAILED
  BANK_SLIP_PAYMENT_CONFIRMED
  BANK_SLIP_CANCELLATION_REQUESTED
  BANK_SLIP_CANCELLED
  BANK_SLIP_SYNCED
  BOARD_MEMBERSHIP_STARTED
  BOARD_MEMBERSHIP_ENDED
}

enum StudentStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum EnrollmentStatus {
  ACTIVE
}

enum BusAssignmentStatus {
  ACTIVE
  ENDED
}

enum BusAssignmentEndReason {
  RELEASED
  SWITCHED
  SUSPENSION
  TERMINATION
}

enum BusAssignmentEventType {
  LINKED
  RELEASED
  SWITCHED
  SUSPENSION_RELEASED
  TERMINATION_RELEASED
}

enum StudentHistoryEventType {
  STUDENT_SUSPENDED
  STUDENT_REACTIVATED
  STUDENT_TERMINATED
  STUDENT_REINSTATED
  STUDENT_REENROLLED
  STUDENT_CARD_ISSUED
  STUDENT_CARD_INVALIDATED
  INVOICE_CREATED
  INVOICE_CANCELLED
  BANK_SLIP_ISSUED
  BANK_SLIP_PAYMENT_CONFIRMED
  BANK_SLIP_CANCELLATION_REQUESTED
  BANK_SLIP_CANCELLED
  BOARD_MEMBERSHIP_STARTED
  BOARD_MEMBERSHIP_ENDED
}

enum StudentSuspensionReason {
  NON_PAYMENT
  INFRACTION
  OTHER
}

enum StudentTerminationReason {
  WITHDRAWAL
  NON_PAYMENT
}

enum BoardMembershipStatus {
  ACTIVE
  ENDED
}

enum StudentCardType {
  STUDENT
  BOARD_MEMBER
}

enum StudentCardStatus {
  ACTIVE
  INVALIDATED
}

enum StudentCardInvalidationReason {
  SUPERSEDED_BY_BOARD_CARD
  BOARD_MEMBERSHIP_ENDED
  STUDENT_TERMINATED
  MANUAL_CORRECTION
  OTHER
}

enum InvoiceStatus {
  OPEN
  PAID
  CANCELLED
}

enum InvoiceCancellationReason {
  MANUAL_CORRECTION
  DUPLICATE
  OTHER
}

enum BankSlipProvider {
  SICREDI
}

enum BankSlipEnvironment {
  SANDBOX
  PRODUCTION
}

enum BankSlipStatus {
  PENDING_ISSUE
  ISSUED
  PAID
  PENDING_CANCELLATION
  CANCELLED
  ISSUE_FAILED
  CANCELLATION_FAILED
  UNKNOWN
}

enum BankSlipSyncRunType {
  AUTOMATIC_OPEN_ISSUED
  MANUAL_OPEN_ISSUED
  MANUAL_PAID_DAY
  MANUAL_INVOICE
}

enum BankSlipSyncRunStatus {
  RUNNING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
  SKIPPED_ALREADY_RUNNING
}

enum BankSlipSyncRunItemStatus {
  CHECKED
  UPDATED
  PAID
  CANCELLED
  PARTIAL_PAYMENT_REVIEW
  NOT_FOUND
  ERROR
}

enum BankSlipIssueBatchStatus {
  DRAFT
  QUEUED
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
  CANCELLED
}

enum BankSlipIssueBatchSource {
  MANUAL
  INSTITUTION
}

enum BankSlipIssueBatchItemStatus {
  QUEUED
  PROCESSING
  ISSUED
  SKIPPED
  FAILED
  UNKNOWN
  CANCELLED
}

enum StudentDocumentType {
  CPF
  RG
  PROOF_OF_ADDRESS
  PROOF_OF_ENROLLMENT
  PHOTO
}

enum StudentDocumentStatus {
  ACTIVE
  REPLACED
  REMOVED
}

enum PreRegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PreRegistrationDocumentStatus {
  UPLOADED
  PROMOTED
  REMOVED
}

model User {
  id                       String                   @id @default(uuid()) @db.Uuid
  name                     String                   @db.VarChar(120)
  email                    String                   @unique @db.VarChar(180)
  passwordHash             String                   @map("password_hash") @db.VarChar(255)
  status                   UserStatus               @default(ACTIVE)
  createdAt                DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastLoginAt              DateTime?                @map("last_login_at") @db.Timestamptz(6)
  roles                    UserRole[]
  auditLogs                SecurityAuditLog[]
  administrativeAuditLogs  AdministrativeAuditLog[]
  uploadedStudentDocuments StudentDocument[]        @relation("StudentDocumentUploadedBy")
  removedStudentDocuments  StudentDocument[]        @relation("StudentDocumentRemovedBy")
  reviewedPreRegistrations PublicPreRegistration[]  @relation("PreRegistrationReviewedBy")
  studentHistoryEvents     StudentHistoryEvent[]    @relation("StudentHistoryPerformedBy")
  boardMembershipsStarted  BoardMembership[]        @relation("BoardMembershipStartedBy")
  boardMembershipsEnded    BoardMembership[]        @relation("BoardMembershipEndedBy")
  studentCardsIssued       StudentCard[]            @relation("StudentCardIssuedBy")
  studentCardsInvalidated  StudentCard[]            @relation("StudentCardInvalidatedBy")
  invoicesCreated          Invoice[]                @relation("InvoiceCreatedBy")
  invoicesCancelled        Invoice[]                @relation("InvoiceCancelledBy")
  bankSlipCancellations    BankSlip[]               @relation("BankSlipCancellationRequestedBy")
  bankSlipSyncRunsStarted  BankSlipSyncRun[]        @relation("BankSlipSyncRunStartedBy")
  bankSlipIssueBatches     BankSlipIssueBatch[]     @relation("BankSlipIssueBatchRequestedBy")
  bankSlipIssueBatchCancels BankSlipIssueBatch[]    @relation("BankSlipIssueBatchCancelledBy")

  @@map("users")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  code        RoleCode   @unique
  description String     @db.VarChar(180)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@map("user_roles")
}

model SecurityAuditLog {
  id        String         @id @default(uuid()) @db.Uuid
  eventType AuditEventType @map("event_type")
  userId    String?        @map("user_id") @db.Uuid
  email     String?        @db.VarChar(180)
  ip        String?        @db.VarChar(80)
  userAgent String?        @map("user_agent") @db.VarChar(255)
  metadata  Json?
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@map("security_audit_logs")
}

model Institution {
  id               String                  @id @default(uuid()) @db.Uuid
  name             String                  @db.VarChar(140)
  normalizedName   String                  @unique @map("normalized_name") @db.VarChar(140)
  status           RecordStatus            @default(ACTIVE)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  enrollments      Enrollment[]
  preRegistrations PublicPreRegistration[]
  bankSlipIssueBatches BankSlipIssueBatch[]

  @@index([status, name])
  @@index([createdAt])
  @@map("institutions")
}

model Shift {
  id               String                  @id @default(uuid()) @db.Uuid
  name             String                  @db.VarChar(80)
  normalizedName   String                  @unique @map("normalized_name") @db.VarChar(80)
  status           RecordStatus            @default(ACTIVE)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  enrollments      Enrollment[]
  preRegistrations PublicPreRegistration[]
  bankSlipIssueBatches BankSlipIssueBatch[]

  @@index([status, name])
  @@index([createdAt])
  @@map("shifts")
}

model Bus {
  id                   String                @id @default(uuid()) @db.Uuid
  name                 String                @db.VarChar(100)
  normalizedName       String                @unique @map("normalized_name") @db.VarChar(100)
  capacity             Int
  status               RecordStatus          @default(ACTIVE)
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignments          BusAssignment[]
  eventsFrom           BusAssignmentEvent[]  @relation("BusAssignmentEventFromBus")
  eventsTo             BusAssignmentEvent[]  @relation("BusAssignmentEventToBus")
  studentHistoryEvents StudentHistoryEvent[]

  @@index([status, name])
  @@index([createdAt])
  @@map("buses")
}

model AdministrativeAuditLog {
  id        String                       @id @default(uuid()) @db.Uuid
  eventType AdministrativeAuditEventType @map("event_type")
  userId    String?                      @map("user_id") @db.Uuid
  domain    String                       @db.VarChar(40)
  recordId  String                       @map("record_id") @db.Uuid
  metadata  Json?
  createdAt DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([domain, recordId, createdAt])
  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@map("administrative_audit_logs")
}

model Person {
  id                  String   @id @default(uuid()) @db.Uuid
  fullName            String   @map("full_name") @db.VarChar(160)
  normalizedName      String   @map("normalized_name") @db.VarChar(160)
  cpf                 String   @db.VarChar(11)
  rg                  String?  @db.VarChar(30)
  birthDate           DateTime @map("birth_date") @db.Date
  phone               String?  @db.VarChar(30)
  email               String?  @db.VarChar(180)
  addressStreet       String   @map("address_street") @db.VarChar(180)
  addressNumber       String   @map("address_number") @db.VarChar(30)
  addressNeighborhood String   @map("address_neighborhood") @db.VarChar(120)
  addressCity         String   @map("address_city") @db.VarChar(120)
  addressZipCode      String?  @map("address_zip_code") @db.VarChar(20)
  addressState        String?  @map("address_state") @db.VarChar(2)
  addressComplement   String?  @map("address_complement") @db.VarChar(120)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  student             Student?

  @@unique([cpf])
  @@index([normalizedName])
  @@index([createdAt])
  @@map("people")
}

model Student {
  id                       String                  @id @default(uuid()) @db.Uuid
  personId                 String                  @unique @map("person_id") @db.Uuid
  status                   StudentStatus           @default(ACTIVE)
  joinedAt                 DateTime                @default(now()) @map("joined_at") @db.Date
  createdAt                DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  person                   Person                  @relation(fields: [personId], references: [id], onDelete: Restrict)
  guardian                 StudentGuardian?
  enrollments              Enrollment[]
  documents                StudentDocument[]
  approvedPreRegistrations PublicPreRegistration[]
  historyEvents            StudentHistoryEvent[]
  boardMemberships         BoardMembership[]
  studentCards             StudentCard[]
  invoices                 Invoice[]

  @@index([status, createdAt])
  @@index([joinedAt])
  @@map("students")
}

model StudentHistoryEvent {
  id                String                    @id @default(uuid()) @db.Uuid
  studentId         String                    @map("student_id") @db.Uuid
  eventType         StudentHistoryEventType   @map("event_type")
  suspensionReason  StudentSuspensionReason?  @map("suspension_reason")
  terminationReason StudentTerminationReason? @map("termination_reason")
  justification     String?                   @db.VarChar(500)
  busSeatReleased   Boolean?                  @map("bus_seat_released")
  busId             String?                   @map("bus_id") @db.Uuid
  busAssignmentId   String?                   @map("bus_assignment_id") @db.Uuid
  boardMembershipId String?                   @map("board_membership_id") @db.Uuid
  studentCardId     String?                   @map("student_card_id") @db.Uuid
  invoiceId         String?                   @map("invoice_id") @db.Uuid
  bankSlipId        String?                   @map("bank_slip_id") @db.Uuid
  performedByUserId String?                   @map("performed_by_user_id") @db.Uuid
  occurredAt        DateTime                  @default(now()) @map("occurred_at") @db.Timestamptz(6)
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  student           Student                   @relation(fields: [studentId], references: [id], onDelete: Restrict)
  bus               Bus?                      @relation(fields: [busId], references: [id], onDelete: SetNull)
  busAssignment     BusAssignment?            @relation(fields: [busAssignmentId], references: [id], onDelete: SetNull)
  boardMembership   BoardMembership?          @relation(fields: [boardMembershipId], references: [id], onDelete: SetNull)
  studentCard       StudentCard?              @relation(fields: [studentCardId], references: [id], onDelete: SetNull)
  invoice           Invoice?                  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  bankSlip          BankSlip?                 @relation(fields: [bankSlipId], references: [id], onDelete: SetNull)
  performedBy       User?                     @relation("StudentHistoryPerformedBy", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([studentId, occurredAt])
  @@index([eventType, occurredAt])
  @@index([busAssignmentId, occurredAt])
  @@index([boardMembershipId, occurredAt])
  @@index([studentCardId, occurredAt])
  @@index([invoiceId, occurredAt])
  @@index([bankSlipId, occurredAt])
  @@map("student_history_events")
}

model BoardMembership {
  id              String                @id @default(uuid()) @db.Uuid
  studentId       String                @map("student_id") @db.Uuid
  status          BoardMembershipStatus @default(ACTIVE)
  startedAt       DateTime              @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt         DateTime?             @map("ended_at") @db.Timestamptz(6)
  startedByUserId String?               @map("started_by_user_id") @db.Uuid
  endedByUserId   String?               @map("ended_by_user_id") @db.Uuid
  startNote       String?               @map("start_note") @db.VarChar(500)
  endNote         String?               @map("end_note") @db.VarChar(500)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  student         Student               @relation(fields: [studentId], references: [id], onDelete: Restrict)
  startedBy       User?                 @relation("BoardMembershipStartedBy", fields: [startedByUserId], references: [id], onDelete: SetNull)
  endedBy         User?                 @relation("BoardMembershipEndedBy", fields: [endedByUserId], references: [id], onDelete: SetNull)
  historyEvents   StudentHistoryEvent[]
  studentCards    StudentCard[]

  @@index([studentId, status])
  @@index([status, createdAt])
  @@map("board_memberships")
}

model StudentGuardian {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @unique @map("student_id") @db.Uuid
  fullName  String   @map("full_name") @db.VarChar(160)
  cpf       String?  @db.VarChar(11)
  rg        String?  @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([cpf])
  @@map("student_guardians")
}

model AcademicYear {
  id               String                  @id @default(uuid()) @db.Uuid
  year             Int                     @unique
  isCurrent        Boolean                 @default(false) @map("is_current")
  status           AcademicYearStatus      @default(ACTIVE)
  archivedAt       DateTime?               @map("archived_at") @db.Timestamptz(6)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  enrollments      Enrollment[]
  preRegistrations PublicPreRegistration[]
  cardSequences    CardSequence[]
  studentCards     StudentCard[]

  @@index([isCurrent])
  @@index([status])
  @@index([createdAt])
  @@map("academic_years")
}

model Enrollment {
  id                  String               @id @default(uuid()) @db.Uuid
  studentId           String               @map("student_id") @db.Uuid
  academicYearId      String               @map("academic_year_id") @db.Uuid
  institutionId       String               @map("institution_id") @db.Uuid
  shiftId             String               @map("shift_id") @db.Uuid
  course              String               @db.VarChar(140)
  grade               String               @db.VarChar(40)
  status              EnrollmentStatus     @default(ACTIVE)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  student             Student              @relation(fields: [studentId], references: [id], onDelete: Restrict)
  academicYear        AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  institution         Institution          @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  shift               Shift                @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  busAssignments      BusAssignment[]
  busAssignmentEvents BusAssignmentEvent[]
  studentCards        StudentCard[]
  invoices            Invoice[]

  @@unique([studentId, academicYearId])
  @@index([academicYearId, status])
  @@index([institutionId])
  @@index([shiftId])
  @@index([createdAt])
  @@map("enrollments")
}

model CardSequence {
  id                 String          @id @default(uuid()) @db.Uuid
  academicYearId     String          @map("academic_year_id") @db.Uuid
  cardType           StudentCardType @map("card_type")
  lastSequenceNumber Int             @default(0) @map("last_sequence_number")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  academicYear       AcademicYear    @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  @@unique([academicYearId, cardType])
  @@index([cardType])
  @@map("card_sequences")
}

model StudentCard {
  id                   String                         @id @default(uuid()) @db.Uuid
  studentId            String                         @map("student_id") @db.Uuid
  enrollmentId         String                         @map("enrollment_id") @db.Uuid
  academicYearId       String                         @map("academic_year_id") @db.Uuid
  boardMembershipId    String?                        @map("board_membership_id") @db.Uuid
  cardType             StudentCardType                @map("card_type")
  sequenceNumber       Int                            @map("sequence_number")
  cardNumber           String                         @map("card_number") @db.VarChar(32)
  status               StudentCardStatus              @default(ACTIVE)
  issuedAt             DateTime                       @default(now()) @map("issued_at") @db.Timestamptz(6)
  invalidatedAt        DateTime?                      @map("invalidated_at") @db.Timestamptz(6)
  invalidationReason   StudentCardInvalidationReason? @map("invalidation_reason")
  invalidationNote     String?                        @map("invalidation_note") @db.VarChar(500)
  issuedByUserId       String?                        @map("issued_by_user_id") @db.Uuid
  invalidatedByUserId  String?                        @map("invalidated_by_user_id") @db.Uuid
  createdAt            DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(6)
  student              Student                        @relation(fields: [studentId], references: [id], onDelete: Restrict)
  enrollment           Enrollment                     @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  academicYear         AcademicYear                   @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  boardMembership      BoardMembership?               @relation(fields: [boardMembershipId], references: [id], onDelete: SetNull)
  issuedBy             User?                          @relation("StudentCardIssuedBy", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  invalidatedBy        User?                          @relation("StudentCardInvalidatedBy", fields: [invalidatedByUserId], references: [id], onDelete: SetNull)
  studentHistoryEvents StudentHistoryEvent[]

  @@unique([academicYearId, cardType, sequenceNumber])
  @@unique([academicYearId, cardType, cardNumber])
  @@index([studentId, academicYearId])
  @@index([enrollmentId])
  @@index([boardMembershipId])
  @@index([cardType, status])
  @@index([status, issuedAt])
  @@map("student_cards")
}

model Invoice {
  id                   String                     @id @default(uuid()) @db.Uuid
  studentId            String                     @map("student_id") @db.Uuid
  enrollmentId         String                     @map("enrollment_id") @db.Uuid
  amountCents          Int                        @map("amount_cents")
  dueDate              DateTime                   @map("due_date") @db.Date
  status               InvoiceStatus              @default(OPEN)
  description          String?                    @db.VarChar(300)
  idempotencyKey       String                     @unique @map("idempotency_key") @db.VarChar(120)
  cancelledAt          DateTime?                  @map("cancelled_at") @db.Timestamptz(6)
  cancellationReason   InvoiceCancellationReason? @map("cancellation_reason")
  cancellationNote     String?                    @map("cancellation_note") @db.VarChar(500)
  createdByUserId      String?                    @map("created_by_user_id") @db.Uuid
  cancelledByUserId    String?                    @map("cancelled_by_user_id") @db.Uuid
  createdAt            DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  student              Student                    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  enrollment           Enrollment                 @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  createdBy            User?                      @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  cancelledBy          User?                      @relation("InvoiceCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  studentHistoryEvents StudentHistoryEvent[]
  bankSlip             BankSlip?
  bankSlipSyncRunItems BankSlipSyncRunItem[]
  bankSlipIssueBatchItems BankSlipIssueBatchItem[]

  @@index([studentId, createdAt])
  @@index([enrollmentId])
  @@index([status, dueDate])
  @@index([createdByUserId, createdAt])
  @@map("invoices")
}

model BankSlip {
  id                            String                     @id @default(uuid()) @db.Uuid
  invoiceId                     String                     @unique @map("invoice_id") @db.Uuid
  provider                      BankSlipProvider           @default(SICREDI)
  environment                   BankSlipEnvironment
  status                        BankSlipStatus             @default(PENDING_ISSUE)
  documentSpecies               String                     @default("RECIBO") @map("document_species") @db.VarChar(40)
  nossoNumero                   String?                    @map("nosso_numero") @db.VarChar(9)
  seuNumero                     String                     @map("seu_numero") @db.VarChar(10)
  txid                          String?                    @db.VarChar(35)
  linhaDigitavel                String?                    @map("linha_digitavel") @db.VarChar(47)
  codigoBarras                  String?                    @map("codigo_barras") @db.VarChar(44)
  originalAmountCents           Int                        @map("original_amount_cents")
  paidAmountCents               Int?                       @map("paid_amount_cents")
  issuedAt                      DateTime?                  @map("issued_at") @db.Timestamptz(6)
  paidAt                        DateTime?                  @map("paid_at") @db.Timestamptz(6)
  cancellationRequestedAt       DateTime?                  @map("cancellation_requested_at") @db.Timestamptz(6)
  cancellationRequestedByUserId String?                    @map("cancellation_requested_by_user_id") @db.Uuid
  cancellationReason            InvoiceCancellationReason? @map("cancellation_reason")
  cancellationNote              String?                    @map("cancellation_note") @db.VarChar(500)
  cancelledAt                   DateTime?                  @map("cancelled_at") @db.Timestamptz(6)
  lastCheckedAt                 DateTime?                  @map("last_checked_at") @db.Timestamptz(6)
  providerStatus                String?                    @map("provider_status") @db.VarChar(80)
  providerErrorCode             String?                    @map("provider_error_code") @db.VarChar(80)
  providerErrorMessage          String?                    @map("provider_error_message") @db.VarChar(500)
  createdAt                     DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  invoice                       Invoice                    @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  cancellationRequestedBy       User?                      @relation("BankSlipCancellationRequestedBy", fields: [cancellationRequestedByUserId], references: [id], onDelete: Restrict)
  studentHistoryEvents          StudentHistoryEvent[]
  syncRunItems                  BankSlipSyncRunItem[]
  issueBatchItems               BankSlipIssueBatchItem[]

  @@unique([provider, environment, seuNumero])
  @@index([provider, environment, nossoNumero])
  @@index([provider, environment, txid])
  @@index([status, updatedAt])
  @@index([lastCheckedAt])
  @@index([cancellationRequestedByUserId, cancellationRequestedAt])
  @@index([paidAt])
  @@index([cancelledAt])
  @@map("bank_slips")
}

model BankSlipSyncRun {
  id              String                @id @default(uuid()) @db.Uuid
  type            BankSlipSyncRunType
  status          BankSlipSyncRunStatus @default(RUNNING)
  startedByUserId String?               @map("started_by_user_id") @db.Uuid
  startedAt       DateTime              @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime?             @map("finished_at") @db.Timestamptz(6)
  scannedCount    Int                   @default(0) @map("scanned_count")
  updatedCount    Int                   @default(0) @map("updated_count")
  paidCount       Int                   @default(0) @map("paid_count")
  cancelledCount  Int                   @default(0) @map("cancelled_count")
  errorCount      Int                   @default(0) @map("error_count")
  metadata        Json?
  startedBy       User?                 @relation("BankSlipSyncRunStartedBy", fields: [startedByUserId], references: [id], onDelete: SetNull)
  items           BankSlipSyncRunItem[]

  @@index([status, startedAt])
  @@index([type, startedAt])
  @@index([startedByUserId, startedAt])
  @@map("bank_slip_sync_runs")
}

model BankSlipSyncRunItem {
  id             String                    @id @default(uuid()) @db.Uuid
  runId          String                    @map("run_id") @db.Uuid
  bankSlipId     String                    @map("bank_slip_id") @db.Uuid
  invoiceId      String                    @map("invoice_id") @db.Uuid
  status         BankSlipSyncRunItemStatus
  previousStatus BankSlipStatus?           @map("previous_status")
  newStatus      BankSlipStatus?           @map("new_status")
  providerStatus String?                   @map("provider_status") @db.VarChar(80)
  attempts       Int                       @default(1)
  errorCode      String?                   @map("error_code") @db.VarChar(80)
  errorMessage   String?                   @map("error_message") @db.VarChar(500)
  checkedAt      DateTime                  @default(now()) @map("checked_at") @db.Timestamptz(6)
  metadata       Json?
  run            BankSlipSyncRun           @relation(fields: [runId], references: [id], onDelete: Cascade)
  bankSlip       BankSlip                  @relation(fields: [bankSlipId], references: [id], onDelete: Restrict)
  invoice        Invoice                   @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([runId, checkedAt])
  @@index([bankSlipId, checkedAt])
  @@index([invoiceId, checkedAt])
  @@index([status, checkedAt])
  @@map("bank_slip_sync_run_items")
}

model BankSlipIssueBatch {
