  @@index([normalizedName])
  @@index([academicYearId])
  @@index([institutionId])
  @@index([shiftId])
  @@map("public_pre_registrations")
}

model PreRegistrationDocument {
  id                          String                        @id @default(uuid()) @db.Uuid
  preRegistrationId           String                        @map("pre_registration_id") @db.Uuid
  documentType                StudentDocumentType           @map("document_type")
  storageKey                  String                        @unique @map("storage_key") @db.VarChar(500)
  originalFileName            String                        @map("original_file_name") @db.VarChar(255)
  storedFileName              String                        @map("stored_file_name") @db.VarChar(120)
  mimeType                    String                        @map("mime_type") @db.VarChar(80)
  extension                   String                        @db.VarChar(10)
  sizeBytes                   Int                           @map("size_bytes")
  checksumSha256              String                        @map("checksum_sha256") @db.VarChar(64)
  status                      PreRegistrationDocumentStatus @default(UPLOADED)
  promotedToStudentDocumentId String?                       @unique @map("promoted_to_student_document_id") @db.Uuid
  createdAt                   DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
